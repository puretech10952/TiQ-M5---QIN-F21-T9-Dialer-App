    <string name="setting_recording_summary">Opgeslagen in Muziek / Gespreksopnamen</string>
    <string name="recording_heading">Waar opnamen worden opgeslagen</string>
    <string name="recording_explain">Bij een opname slaat de ingebouwde recorder audio op in de map Muziek. Deze app verplaatst elke opname naar een submap, <b>Muziek / Gespreksopnamen</b>.\n\nDit vereist de machtiging "Toegang tot alle bestanden". Zonder deze machtiging werken opnamen maar blijven ze in de map Muziek.</string>
    <string name="recording_grant">Toegang tot alle bestanden toestaan</string>
    <string name="recording_supported_heading">Apparaatondersteuning</string>
    <string name="recording_supported_devices">Gespreksopname wordt alleen ondersteund op de <b>TiQ Mini M5</b> en de <b>Qin F21</b>.</string>
    <string name="recording_access_on">Status: Aan — opnamen naar Muziek / Gespreksopnamen</string>
    <string name="recording_access_off">Status: Uit — opnamen blijven in Muziek</string>
    <string name="setting_redirect">Startscherm verzendtoets</string>
    <string name="setting_redirect_summary">De verzendtoets opent deze kiezer overal</string>
    <string name="redirect_heading">Deze kiezer openen met de verzendtoets</string>
    <string name="redirect_explain">Op deze telefoon is de verzendtoets gekoppeld aan de standaardkiezer. Deze optionele helper detecteert wanneer de standaardkiezer wordt geopend en schakelt onmiddellijk over naar PureTech Phone.\n\nSchakel in via Toegankelijkheid → PureTech Phone omleiding.</string>
