    <!-- Keep running in background (foreground keep-alive + battery exemption) -->
    <string name="setting_keepalive">Keep running in background</string>
    <string name="setting_keepalive_summary">Stops the phone from being killed so incoming calls always show</string>
    <string name="keepalive_heading">Always show incoming calls</string>
    <string name="keepalive_explain">Some phones (like the Qin F21) aggressively freeze background apps after a few minutes, so an incoming call can\'t open the call screen until you reopen the app by hand. The built-in stock dialer is exempted by the manufacturer; a downloaded app can\'t add itself to that list.\n\nTurning this on keeps a small background service running so the phone never freezes the dialer, and incoming calls always appear. The trade-off is a permanent quiet notification in the shade that you can\'t swipe away. Leave it off unless you\'re missing incoming calls.</string>
    <string name="keepalive_switch_label">Keep the phone app running</string>
    <string name="keepalive_battery_heading">Battery optimization</string>
    <string name="keepalive_battery_explain">For best results also exempt this app from battery optimization, so the system doesn\'t put it to sleep.</string>
    <string name="keepalive_battery_button">Don\'t optimize this app</string>
    <string name="keepalive_battery_on">Status: Not optimized (good)</string>
    <string name="keepalive_battery_off">Status: Optimized (may be killed)</string>
    <string name="keepalive_channel">Background service</string>
    <string name="keepalive_notif_title">Phone is ready</string>
    <string name="keepalive_notif_text">Keeping incoming calls reliable</string>

    <!-- Call recordings folder -->
    <string name="setting_recording">Call recordings</string>
    <string name="setting_recording_summary">Saved to Music / Call recordings</string>
    <string name="recording_heading">Where recordings are saved</string>
    <string name="recording_explain">When you record a call, the phone\'s built-in recorder saves the audio (both sides) into the Music folder. This app then moves each new recording into a tidy sub-folder, <b>Music / Call recordings</b>.\n\nMoving those files needs the “All files access” permission, because the recording is created by the system recorder, not by this app. Without it, recordings still work — they just stay loose in the Music folder.</string>
    <string name="recording_grant">Allow All files access</string>
    <string name="recording_access_on">Status: On — recordings go to Music / Call recordings</string>
    <string name="recording_access_off">Status: Off — recordings stay in Music</string>

    <!-- Send-key redirect (accessibility helper) -->
    <string name="setting_redirect">Home Send key</string>
    <string name="setting_redirect_summary">Make the Send key open this dialer everywhere</string>
    <string name="redirect_heading">Open this dialer with the Send key</string>
    <string name="redirect_explain">On this phone the Home screen\'s Send/Call key is locked by the launcher to the built-in stock dialer, and a normal app can\'t change that. This optional helper watches only for the stock dialer opening and instantly switches to PureTech Phone, so the Send key always lands here. It reacts to nothing else. After you turn it on, you may briefly see the stock dialer flash before it switches.\n\nTurn it on under Accessibility → PureTech Phone redirect.</string>
    <string name="redirect_open_accessibility">Open Accessibility settings</string>
    <string name="redirect_status_on">Status: On</string>
    <string name="redirect_status_off">Status: Off</string>
    <string name="redirect_service_label">PureTech Phone redirect</string>
    <string name="redirect_service_desc">Lets the Home screen Send/Call key open PureTech Phone instead of the built-in stock dialer. It only reacts to the stock dialer opening and does not read any screen content.</string>
    <string name="redirect_service_summary">Opens PureTech Phone when the Send key triggers the stock dialer</string>
</resources>
