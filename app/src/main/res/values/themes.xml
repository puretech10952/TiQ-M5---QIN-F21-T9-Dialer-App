<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.M5Dialer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Match the app's themed background so the bar blends in. -->
        <item name="android:statusBarColor">?attr/colorSurfaceContainer</item>
        <item name="android:navigationBarColor">?attr/colorSurfaceContainer</item>
        <!-- Icon contrast follows the theme: dark icons in light, light icons in dark. -->
        <item name="android:windowLightStatusBar">@bool/light_status_icons</item>
        <item name="android:windowLightNavigationBar">@bool/light_status_icons</item>
    </style>

    <!-- In-call screen: follows the app's light/dark theme via @color/incall_* -->
    <style name="Theme.M5Dialer.InCall" parent="Theme.M5Dialer">
        <item name="android:statusBarColor">@color/incall_bg</item>
        <item name="android:navigationBarColor">@color/incall_bg</item>
        <item name="android:windowLightStatusBar">@bool/incall_light_status</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ControlGroup">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ControlIcon">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/bg_circle_control</item>
        <item name="android:padding">16dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:tint">@color/incall_control_icon</item>
    </style>

    <style name="ControlLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/incall_subtitle</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CallLogAction" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="iconGravity">textStart</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Google-Dialer shade button (full-width grey, icon + label, left aligned) -->
    <style name="LogShadeButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:background">@drawable/bg_log_shade</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:drawablePadding">24dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:drawableTint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Material 3 bottom-sheet action rows (call details) -->
    <style name="SheetActionRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="SheetActionIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="SheetActionText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="BottomNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="BottomNavIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="BottomNavLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Settings list rows -->
    <style name="SettingRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingVertical">16dp</item>
    </style>

    <!-- M3-expressive settings: section header, grouped card, row, icon chip -->
    <style name="SettingsSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingTop">22dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="SettingsGroupCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">12dp</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLowest</item>
        <!-- No outline; the grouped rows provide the shape (avoids a "cage" border). -->
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Small transparent gap that separates rows of the same group (≈1mm). -->
    <style name="LogRowDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
    </style>

    <!-- Small transparent gap between rows inside a settings group. -->
    <style name="SettingRowDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
    </style>

    <style name="SettingRowM3">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_rowgroup_middle</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">16dp</item>
    </style>

    <style name="SettingIconChip">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="SettingTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SettingSummary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Call-duration stat cards -->
    <style name="StatRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">18dp</item>
    </style>

    <style name="StatIcon">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginEnd">18dp</item>
        <item name="android:padding">9dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:background">@drawable/bg_circle_solid</item>
        <item name="android:backgroundTint">?attr/colorSecondaryContainer</item>
        <item name="android:tint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="StatText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="StatLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="StatSub">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="StatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- On-screen dial pad keys (MainActivity) -->
    <style name="DialPadKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_dialpad_key</item>
    </style>

    <!-- In-call DTMF key: same width/style as the dialer key, original 46dp height,
         with a fill that shows on the white in-call surface. -->
    <style name="DialPadKeyInCall" parent="DialPadKey">
        <item name="android:layout_height">46dp</item>
        <item name="android:background">@drawable/bg_dtmf_key</item>
    </style>

    <style name="DialPadDigit">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialPadLetters">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="DialPadRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:weightSum">3</item>
    </style>

    <style name="DtmfKey">
        <item name="android:layout_width">78dp</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/incall_name</item>
        <item name="android:background">@drawable/bg_dtmf_key</item>
    </style>
</resources>
