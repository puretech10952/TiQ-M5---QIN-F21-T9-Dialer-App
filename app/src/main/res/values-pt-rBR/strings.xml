    <string name="setting_recording_summary">Salvas em Música / Gravações de chamadas</string>
    <string name="recording_heading">Onde as gravações são salvas</string>
    <string name="recording_explain">Ao gravar, o gravador integrado salva o áudio na pasta Música. Este app move cada gravação para uma subpasta, <b>Música / Gravações de chamadas</b>.\n\nIsso requer a permissão "Acesso a todos os arquivos". Sem ela, as gravações funcionam mas ficam na pasta Música.</string>
    <string name="recording_grant">Permitir acesso a todos os arquivos</string>
    <string name="recording_supported_heading">Suporte do dispositivo</string>
    <string name="recording_supported_devices">A gravação de chamadas é suportada apenas no <b>TiQ Mini M5</b> e no <b>Qin F21</b>.</string>
    <string name="recording_access_on">Status: Ativado — gravações em Música / Gravações de chamadas</string>
    <string name="recording_access_off">Status: Desativado — gravações em Música</string>
