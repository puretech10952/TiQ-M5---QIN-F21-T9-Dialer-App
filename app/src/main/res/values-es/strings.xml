    <string name="keypad_switch_label">Mostrar botón de teclado flotante</string>
    <string name="keypad_switch_desc">Este teléfono marca con sus teclas físicas, por lo que no necesita teclado en pantalla. Actívalo para añadir un botón flotante en la pantalla de marcación que abre un teclado en pantalla.</string>
    <string name="keypad_default_open_label">Abrir teclado automáticamente</string>
    <string name="keypad_default_open_desc">Muestra el teclado en pantalla cada vez que abres el marcador. Puedes minimizarlo y se abrirá de nuevo la próxima vez. Para quienes prefieren marcar en pantalla.</string>
    <string name="keypad_big_label">Teclado grande</string>
    <string name="keypad_big_desc">Amplía el teclado en pantalla para un smartphone normal, y añade un botón verde de llamada en la parte inferior para marcar con el dedo.</string>
