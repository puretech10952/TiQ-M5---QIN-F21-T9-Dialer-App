    <string name="voicemail_text">Tienes un nuevo mensaje de voz. Toca para llamar.</string>
    <string name="setting_keepalive">Mantener en segundo plano</string>
    <string name="setting_keepalive_summary">Evita que el teléfono se cierre para que las llamadas entrantes siempre aparezcan</string>
    <string name="keepalive_heading">Mostrar siempre las llamadas entrantes</string>
    <string name="keepalive_explain">Algunos teléfonos (como el Qin F21) cierran agresivamente las apps en segundo plano después de unos minutos, por lo que una llamada entrante no puede mostrar la pantalla. El marcador de fábrica está exento por el fabricante; una app de terceros no puede añadirse a esa lista.\n\nActivar esto mantiene un pequeño servicio en segundo plano para que el teléfono nunca cierre el marcador y las llamadas entrantes siempre aparezcan. La contrapartida es una notificación silenciosa permanente que no puedes eliminar. Déjalo desactivado a menos que estés perdiendo llamadas.</string>
    <string name="keepalive_switch_label">Mantener la app de teléfono activa</string>
    <string name="keepalive_battery_heading">Optimización de batería</string>
    <string name="keepalive_battery_explain">Para mejores resultados, exime también esta app de la optimización de batería, para que el sistema no la suspenda.</string>
    <string name="keepalive_battery_button">No optimizar esta app</string>
    <string name="keepalive_battery_on">Estado: No optimizada (correcto)</string>
    <string name="keepalive_battery_off">Estado: Optimizada (puede cerrarse)</string>
    <string name="keepalive_channel">Servicio en segundo plano</string>
    <string name="keepalive_notif_title">Teléfono listo</string>
    <string name="keepalive_notif_text">Llamadas entrantes garantizadas</string>
    <string name="setting_recording">Grabaciones de llamadas</string>
    <string name="setting_recording_summary">Guardadas en Música / Grabaciones de llamadas</string>
    <string name="recording_heading">Dónde se guardan las grabaciones</string>
    <string name="recording_explain">Al grabar una llamada, el grabador integrado guarda el audio (ambas partes) en la carpeta Música. Esta app luego mueve cada grabación a una subcarpeta, <b>Música / Grabaciones de llamadas</b>.\n\nMover esos archivos requiere el permiso de "Acceso a todos los archivos", ya que las grabaciones las crea el sistema. Sin ese permiso las grabaciones funcionan, pero permanecen en la carpeta Música.</string>
    <string name="recording_grant">Permitir acceso a todos los archivos</string>
    <string name="recording_supported_heading">Compatibilidad</string>
    <string name="recording_supported_devices">La grabación de llamadas solo es compatible con el <b>TiQ Mini M5</b> y el <b>Qin F21</b>. En otros teléfonos el botón de grabación puede no tener efecto.</string>
    <string name="recording_access_on">Estado: Activado — las grabaciones van a Música / Grabaciones de llamadas</string>
    <string name="recording_access_off">Estado: Desactivado — las grabaciones permanecen en Música</string>
    <string name="setting_redirect">Tecla Enviar en inicio</string>
    <string name="setting_redirect_summary">Hace que la tecla Enviar abra este marcador en cualquier lugar</string>
    <string name="redirect_heading">Abrir este marcador con la tecla Enviar</string>
    <string name="redirect_explain">En este teléfono la tecla Enviar de la pantalla de inicio está vinculada al marcador de fábrica, y una app normal no puede cambiarlo. Este asistente opcional detecta cuándo se abre el marcador de fábrica y cambia instantáneamente a PureTech Phone. Después de activarlo, podrías ver brevemente el marcador de fábrica antes de que cambie.\n\nActívalo en Accesibilidad → Redirección de PureTech Phone.</string>
    <string name="redirect_open_accessibility">Abrir ajustes de accesibilidad</string>
    <string name="redirect_status_on">Estado: Activado</string>
    <string name="redirect_status_off">Estado: Desactivado</string>
    <string name="redirect_service_label">Redirección de PureTech Phone</string>
    <string name="redirect_service_desc">Permite que la tecla Enviar de la pantalla de inicio abra PureTech Phone en lugar del marcador de fábrica. Solo reacciona al abrirse el marcador de fábrica y no lee ningún contenido de pantalla.</string>
    <string name="redirect_service_summary">Abre PureTech Phone cuando la tecla Enviar activa el marcador de fábrica</string>
