    <string name="keypad_switch_label">फ्लोटिंग कीपैड बटन दिखाएं</string>
    <string name="keypad_switch_desc">यह फोन अपनी भौतिक कुंजियों से डायल करता है, इसलिए स्क्रीन कीपैड की जरूरत नहीं। स्क्रीन कीपैड खोलने वाला एक छोटा फ्लोटिंग बटन जोड़ने के लिए सक्षम करें।</string>
    <string name="keypad_default_open_label">कीपैड स्वचालित खोलें</string>
    <string name="keypad_default_open_desc">हर बार डायलर खोलने पर स्क्रीन कीपैड दिखाता है। आप इसे छोटा कर सकते हैं और यह अगली बार फिर खुलेगा।</string>
    <string name="keypad_big_label">बड़ा कीपैड</string>
    <string name="keypad_big_desc">स्मार्टफोन के लिए स्क्रीन कीपैड बड़ा करता है और टैप करने के लिए नीचे हरा कॉल बटन जोड़ता है।</string>
