    <string name="setting_keepalive">पृष्ठभूमि में चलते रहें</string>
    <string name="setting_keepalive_summary">फोन को बंद होने से रोकता है ताकि आने वाली कॉल हमेशा दिखें</string>
    <string name="keepalive_heading">आने वाली कॉल हमेशा दिखाएं</string>
    <string name="keepalive_explain">कुछ फोन (जैसे Qin F21) पृष्ठभूमि ऐप को आक्रामक रूप से फ्रीज करते हैं। डिफ़ॉल्ट डायलर निर्माता द्वारा छूट दिया गया है; एक डाउनलोड किया गया ऐप खुद को सूची में नहीं जोड़ सकता।\n\nइसे चालू करने से एक छोटी पृष्ठभूमि सेवा चलती रहेगी ताकि आने वाली कॉल हमेशा दिखें। नुकसान एक स्थायी साइलेंट नोटिफिकेशन है। कॉल न चूकने पर बंद रखें।</string>
    <string name="keepalive_switch_label">फोन ऐप को सक्रिय रखें</string>
    <string name="keepalive_battery_heading">बैटरी अनुकूलन</string>
    <string name="keepalive_battery_explain">सर्वोत्तम परिणामों के लिए, इस ऐप को बैटरी अनुकूलन से भी बाहर करें।</string>
    <string name="keepalive_battery_button">इस ऐप को अनुकूलित न करें</string>
    <string name="keepalive_battery_on">स्थिति: अनुकूलित नहीं (अच्छा)</string>
    <string name="keepalive_battery_off">स्थिति: अनुकूलित (बंद हो सकता है)</string>
    <string name="keepalive_channel">पृष्ठभूमि सेवा</string>
    <string name="keepalive_notif_title">फोन तैयार</string>
    <string name="keepalive_notif_text">आने वाली कॉल विश्वसनीय रूप से काम कर रही है</string>
    <string name="setting_recording">कॉल रिकॉर्डिंग</string>
    <string name="setting_recording_summary">संगीत / कॉल रिकॉर्डिंग में सहेजा गया</string>
    <string name="recording_heading">रिकॉर्डिंग कहां सहेजी जाती है</string>
    <string name="recording_explain">कॉल रिकॉर्ड करते समय, बिल्ट-इन रिकॉर्डर ऑडियो को संगीत फोल्डर में सहेजता है। यह ऐप प्रत्येक रिकॉर्डिंग को एक सबफ़ोल्डर में ले जाता है, <b>संगीत / कॉल रिकॉर्डिंग</b>।\n\nइसके लिए "सभी फाइलों तक पहुंच" अनुमति की आवश्यकता है। अनुमति के बिना रिकॉर्डिंग काम करती है लेकिन संगीत फोल्डर में रहती है।</string>
    <string name="recording_grant">सभी फाइलों तक पहुंच की अनुमति दें</string>
    <string name="recording_supported_heading">डिवाइस समर्थन</string>
    <string name="recording_supported_devices">कॉल रिकॉर्डिंग केवल <b>TiQ Mini M5</b> और <b>Qin F21</b> पर समर्थित है।</string>
    <string name="recording_access_on">स्थिति: चालू — रिकॉर्डिंग संगीत / कॉल रिकॉर्डिंग में जाती है</string>
    <string name="recording_access_off">स्थिति: बंद — रिकॉर्डिंग संगीत में रहती है</string>
