    <string name="redirect_status_off">État : Désactivé</string>
    <string name="redirect_service_label">Redirection PureTech Phone</string>
    <string name="redirect_service_desc">Permet à la touche Envoi d\'ouvrir PureTech Phone au lieu du clavier de fábrica. Ne réagit qu\'à l\'ouverture du clavier de fábrica.</string>
    <string name="redirect_service_summary">Ouvre PureTech Phone quand la touche Envoi déclenche le clavier de fábrica</string>
