    <string name="setting_recording">Registrazioni chiamate</string>
    <string name="setting_recording_summary">Salvate in Musica / Registrazioni chiamate</string>
    <string name="recording_heading">Dove vengono salvate le registrazioni</string>
    <string name="recording_explain">Durante una registrazione, il registratore integrato salva l\'audio nella cartella Musica. Questa app sposta ogni registrazione in una sottocartella, <b>Musica / Registrazioni chiamate</b>.\n\nQuesto richiede il permesso "Accesso a tutti i file". Senza di esso le registrazioni funzionano ma rimangono nella cartella Musica.</string>
    <string name="recording_grant">Consenti accesso a tutti i file</string>
    <string name="recording_supported_heading">Compatibilità dispositivo</string>
    <string name="recording_supported_devices">La registrazione delle chiamate è supportata solo su <b>TiQ Mini M5</b> e <b>Qin F21</b>.</string>
    <string name="recording_access_on">Stato: Attivo — registrazioni in Musica / Registrazioni chiamate</string>
    <string name="recording_access_off">Stato: Disattivo — registrazioni in Musica</string>
    <string name="setting_redirect">Tasto Invia in Home</string>
    <string name="setting_redirect_summary">Il tasto Invia apre questo tastierino ovunque</string>
    <string name="redirect_heading">Apri questo tastierino con il tasto Invia</string>
    <string name="redirect_explain">Su questo telefono il tasto Invia è collegato al tastierino di fabbrica. Questo assistente opzionale rileva quando si apre il tastierino di fabbrica e passa immediatamente a PureTech Phone.\n\nAttivalo in Accessibilità → Reindirizzamento PureTech Phone.</string>
    <string name="redirect_open_accessibility">Apri impostazioni accessibilità</string>
