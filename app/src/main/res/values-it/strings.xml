    <string name="redirect_status_off">Stato: Disattivo</string>
    <string name="redirect_service_label">Reindirizzamento PureTech Phone</string>
    <string name="redirect_service_desc">Permette al tasto Invia di aprire PureTech Phone invece del tastierino di fabbrica. Reagisce solo all\'apertura del tastierino di fabbrica.</string>
    <string name="redirect_service_summary">Apre PureTech Phone quando il tasto Invia attiva il tastierino di fabbrica</string>
