<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Host content: a swappable fragment container with the persistent bottom bar
         and the on-screen keypad overlaying its bottom. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:fitsSystemWindows="true">

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Bottom stack: the on-screen keypad (when visible) sits above the nav bar. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical">

        <!-- On-screen dial pad (OSK). Always above the nav bar when shown. -->
        <LinearLayout
            android:id="@+id/dialpadPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceContainerHigh"
            android:orientation="vertical"
            android:paddingBottom="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/btnMinimize"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:layout_gravity="center_horizontal"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/hide_keypad"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_arrow_drop_down"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout style="@style/DialPadRow">
                <LinearLayout android:id="@+id/key1" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="1" />
                    <TextView style="@style/DialPadLetters" android:text="" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key2" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="2" />
                    <TextView style="@style/DialPadLetters" android:text="ABC" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key3" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="3" />
                    <TextView style="@style/DialPadLetters" android:text="DEF" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/DialPadRow">
                <LinearLayout android:id="@+id/key4" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="4" />
                    <TextView style="@style/DialPadLetters" android:text="GHI" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key5" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="5" />
                    <TextView style="@style/DialPadLetters" android:text="JKL" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key6" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="6" />
                    <TextView style="@style/DialPadLetters" android:text="MNO" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/DialPadRow">
                <LinearLayout android:id="@+id/key7" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="7" />
                    <TextView style="@style/DialPadLetters" android:text="PQRS" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key8" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="8" />
                    <TextView style="@style/DialPadLetters" android:text="TUV" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key9" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="9" />
                    <TextView style="@style/DialPadLetters" android:text="WXYZ" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/DialPadRow">
                <LinearLayout android:id="@+id/keyStar" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="*" />
                    <TextView style="@style/DialPadLetters" android:text="" />
                </LinearLayout>
                <LinearLayout android:id="@+id/key0" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="0" />
                    <TextView style="@style/DialPadLetters" android:text="+" />
                </LinearLayout>
                <LinearLayout android:id="@+id/keyHash" style="@style/DialPadKey">
                    <TextView style="@style/DialPadDigit" android:text="#" />
                    <TextView style="@style/DialPadLetters" android:text="" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnDialBig"
                android:layout_width="150dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_dial_pill"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/ctl_answer"
                android:padding="15dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_call"
                android:visibility="gone"
                app:tint="#FFFFFF"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- The ONE persistent Material 3 NavigationBar (animated tonal indicator). -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            style="@style/Widget.Material3.BottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_bottom_nav"
            android:elevation="10dp"
            app:itemPaddingTop="6dp"
            app:itemPaddingBottom="8dp"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

        </LinearLayout><!-- end bottom stack -->
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu">

        <TextView
            android:id="@+id/drawerVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingHorizontal="24dp"
            android:paddingVertical="20dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            tools:text="PureTech Dialer Version 1.3.3 Beta" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
