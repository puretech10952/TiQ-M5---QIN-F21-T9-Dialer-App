<?xml version="1.0" encoding="utf-8"?>
<!-- Root is a per-day group cell: the adapter sets a position-aware white
     background (rounded top/bottom of the group) so each day reads as one card. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:orientation="vertical"
    android:background="@drawable/bg_log_group_single">

        <!-- Inset split between rows of the same day (hidden on the first row). -->
        <View
            android:id="@+id/rowDivider"
            style="@style/LogRowDivider"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Main row: tap to expand the shade, phone icon to call -->
        <LinearLayout
            android:id="@+id/row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <FrameLayout
                android:id="@+id/avatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/avatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_solid"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="Y"
                    tools:visibility="visible" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/avatarPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        tools:text="Yumi" />

                    <ImageView
                        android:id="@+id/hd"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_hd"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="15sp"
                        android:visibility="gone"
                        tools:text="(4)"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/typeIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_call_made"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        tools:text="Mobile • 12:45 AM" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/callBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/ctl_answer"
                android:padding="12dp"
                android:src="@drawable/ic_call_outline"
                app:tint="?attr/colorPrimary" />
        </LinearLayout>

        <!-- Expanded shade (opens under the row on tap) -->
        <LinearLayout
            android:id="@+id/actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/actionAddContact"
                style="@style/LogShadeButton"
                android:drawableStart="@drawable/ic_person_add"
                android:text="@string/log_add_contact"
                android:visibility="gone" />

            <TextView
                android:id="@+id/actionMessage"
                style="@style/LogShadeButton"
                android:drawableStart="@drawable/ic_message"
                android:text="@string/log_message" />

            <TextView
                android:id="@+id/actionHistory"
                style="@style/LogShadeButton"
                android:drawableStart="@drawable/ic_history"
                android:text="@string/log_history" />

            <TextView
                android:id="@+id/actionCopy"
                style="@style/LogShadeButton"
                android:drawableStart="@drawable/ic_content_copy"
                android:text="@string/log_copy" />
        </LinearLayout>
</LinearLayout>
